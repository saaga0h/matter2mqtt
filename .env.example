# Docker Compose Environment Variables for matter2mqtt

# ============================================================================
# USB Device Configuration
# ============================================================================
# IMPORTANT: Find your device path with: ls -l /dev/serial/by-id/
# Using /dev/serial/by-id/* paths is HIGHLY RECOMMENDED (persistent across reboots)
#
# Examples:
# - Nordic nRF52840: /dev/serial/by-id/usb-SEGGER_J-Link_000683012345-if00
# - SiLabs CP2102: /dev/serial/by-id/usb-Silicon_Labs_CP2102N_USB_to_UART_Bridge_Controller_abc123
# - Generic USB serial: /dev/ttyACM0 or /dev/ttyUSB0 (NOT recommended)

# Thread dongle for OTBR
THREAD_DEVICE=/dev/ttyACM0

# Matter dongle for matter2mqtt (can be same as THREAD_DEVICE)
MATTER_DEVICE=/dev/ttyACM0

# ============================================================================
# Open Thread Border Router (OTBR) Configuration
# ============================================================================

# Thread Network Name (up to 16 characters)
NETWORK_NAME=OpenThreadDemo

# Thread Channel (11-26, avoid WiFi channels if possible)
CHANNEL=15

# PAN ID (0x0000-0xFFFF, recommend unique value)
PANID=0x1234

# Extended PAN ID (16 hex digits)
EXTPANID=1111111122222222

# Network Key (32 hex digits - CHANGE THIS for security!)
NETWORKKEY=00112233445566778899aabbccddeeff

# ============================================================================
# matter2mqtt Configuration
# ============================================================================

# Uncomment to enable mock mode (testing without hardware)
# MOCK_CHIPTOOL=true

# MQTT Configuration (if overriding config.yaml)
# MQTT_SERVER=localhost
# MQTT_PORT=1883
# MQTT_USER=
# MQTT_PASSWORD=
# MQTT_BASE_TOPIC=matter

# ============================================================================
# Optional: Container Timezone
# ============================================================================
# TZ=America/New_York
